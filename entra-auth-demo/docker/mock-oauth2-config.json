{
  "entra": {
    "tokenCallbacks": [
      {
        "issuerId": "entra",
        "tokenExpiry": 3600,
        "requestMappings": [
          {
            "requestParam": "grant_type",
            "match": "client_credentials",
            "claims": {
              "sub": "demo-client",
              "oid": "00000000-0000-0000-0000-000000000001",
              "tid": "test-tenant-id-0000",
              "roles": ["API.Read"],
              "appid": "demo-app-id"
            }
          }
        ]
      }
    ]
  }
}
