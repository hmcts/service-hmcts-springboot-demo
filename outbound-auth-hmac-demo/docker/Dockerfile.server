# Build context must be repo root (service-hmcts-springboot-demo)
# so that gradle/ and outbound-auth-hmac-demo/server are available.

FROM eclipse-temurin:21-jdk AS build
WORKDIR /app
COPY gradle /app/gradle
COPY outbound-auth-hmac-demo/server /app/server
WORKDIR /app/server
RUN ./gradlew bootJar --no-daemon

FROM eclipse-temurin:21-jre
COPY --from=build /app/server/build/libs/*.jar app.jar
EXPOSE 8080
ENTRYPOINT ["java", "-jar", "/app.jar"]
