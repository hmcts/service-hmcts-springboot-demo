# Build context must be repo root (service-hmcts-springboot-demo)
# so that gradle/ and outbound-auth-hmac-demo/client are available.

FROM eclipse-temurin:25.0.2_10-jdk AS build
WORKDIR /app
COPY gradle /app/gradle
COPY outbound-auth-hmac-demo/client /app/client
WORKDIR /app/client
RUN ./gradlew bootJar --no-daemon

FROM eclipse-temurin:25.0.2_10-jre
COPY --from=build /app/client/build/libs/*.jar app.jar
EXPOSE 8081
ENTRYPOINT ["java", "-jar", "/app.jar"]
